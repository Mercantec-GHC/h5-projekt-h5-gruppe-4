meta {
  name: Start Game
  type: http
  seq: 2
}

post {
  url: https://{{baseUrl}}/game/start
  body: none
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

script:post-response {
  const data = res.body;
  
  bru.setEnvVar("gameId", data.gameId)
  bru.setEnvVar("userId", data.userId)
}

settings {
  encodeUrl: true
  timeout: 0
}
