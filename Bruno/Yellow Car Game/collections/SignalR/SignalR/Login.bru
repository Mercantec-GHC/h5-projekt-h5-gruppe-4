meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: https://{{baseUrl}}/auth
  body: json
  auth: inherit
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:post-response {
  const data = res.body;
  
  bru.setEnvVar("jwtToken", data.jwtToken)
}

settings {
  encodeUrl: true
  timeout: 0
}
