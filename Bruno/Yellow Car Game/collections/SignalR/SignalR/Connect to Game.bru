meta {
  name: Connect to Game
  type: ws
  seq: 4
}

ws {
  url: wss://{{baseUrl}}/game/hub
  body: ws
  auth: none
}

body:ws {
  name: message 1
  content: '''
    {"protocol":"json","version":1}
    
    {
      "type": 1,
      "target": "JoinGame",
      "arguments": [
        "{{gameId}}",
        "{{userId}}"
      ]
    }
    
    {
      "type": 1,
      "target": "PlayerAction",
      "arguments": [
        "{{gameId}}",
        "setReadyStatus",
        "true"
      ]
    }
  '''
}
