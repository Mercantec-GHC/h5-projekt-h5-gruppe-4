# Environment configuration for ASP.NET Core application
ASPNETCORE_ENVIRONMENT=Development

# HTTP Ports
API_HTTP_PORT=8080
FRONTEND_HTTP_PORT=3000

# JWT Authentication settings
JWT_AUDIENCE=your-audience
JWT_ISSUER=your-issuer
JWT_SECRET=your-secret-key

# Database connection string
POSTGRES_CONNECTION=Server=your_server;Database=your_database;User Id=your_user;Password=your_password;

# S3 Storage settings
S3_ENDPOINT=your-s3-endpoint
S3_USE_SSL=true
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Password complexity regex (at least 8 characters, including uppercase, lowercase, digit, and special character)
PASSWORD_REGEX=^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9])\S{8,}$

# Next.js public environment variables (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_STORAGE_KEY=HUDszfOrBG1BRNXJPEZyTpJ4cHPJOrFJBkerC4zKKxE=
NEXT_PUBLIC_API_URL=http://yellowcargame.api:3000